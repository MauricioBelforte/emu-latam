{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "powershell -Command \"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction Ignore; npx electron-vite dev\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 npx electron .",
    "build": "electron-vite build",
    "lint": "eslint .",
    "preview": "electron-vite preview",
    "test:stable": "node test_stable_flows.js",
    "test:ux": "node test_ux_features.js",
    "test:antilag": "node test_antilag.js",
    "test:mitm": "node test_mitm_relay.js",
    "package": "node scripts/package.js"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "styled-components": "^6.3.10",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "@eslint/js": "^9.39.1",
    "@heroiclabs/nakama-js": "^2.8.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^26.7.0",
    "electron-packager": "^17.1.2",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.emulatam.app",
    "productName": "Emu Latam Setup",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../backend",
        "to": "extraResources/backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../retroarch",
        "to": "extraResources/retroarch",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../relay-server",
        "to": "extraResources/relay-server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
